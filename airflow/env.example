# ============================================================
# Local Airflow — .env
# Copy this to airflow/.env and fill in your values.
# NEVER commit .env to git.
# ============================================================

# --- Airflow secrets (generate once, keep stable) ---
# Generate Fernet key:  python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Generate secret key:  python3 -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW_FERNET_KEY=<generate-and-paste>
AIRFLOW_SECRET_KEY=<generate-and-paste>
AIRFLOW_ADMIN_PASSWORD=<choose-a-password>

# --- AWS credentials (IAM user: youtube-pipeline-admin) ---
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>

# --- Pipeline config ---
YOUTUBE_BRONZE_BUCKET=youtube-raw-dev-900932787422

# dbt project path on your MacBook (absolute path on the external SSD)
# This gets bind-mounted into the Airflow container at /opt/dbt/youtube_analytics
YOUTUBE_DBT_PROJECT_DIR=/Volumes/Crucial 500GB/youtube_analytics_pipeline/dbt

# dbt profiles dir — typically ~/.dbt
YOUTUBE_DBT_PROFILES_DIR=/Users/<your-username>/.dbt

# --- Airflow UID (run: echo $(id -u) on your Mac to get this) ---
AIRFLOW_UID=501
