create table "awsdatacatalog"."dbt_gold"."fct_momentum_videos__ha"
    with (
      table_type='iceberg',
      is_external=false,location='s3://youtube-analytics-gold-dev/dbt/dbt_gold/fct_momentum_videos/e5d1af4a-8a7c-48c8-b94e-49a4a8ce7df1',
