-- /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "youtube_analytics", "target_name": "dev", "node_id": "model.youtube_analytics.fct_momentum_videos"} */
create table "awsdatacatalog"."dbt_gold"."fct_momentum_videos"
    with (
      table_type='iceberg',
      is_external=false,location='s3://youtube-analytics-gold-dev/dbt/dbt_gold/fct_momentum_videos/8b9c30ec-c45e-4a87-9747-856f7135a250',
