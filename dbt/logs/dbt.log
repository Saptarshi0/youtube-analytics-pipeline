enriched as (
    select
        category_id,
        case category_id
            when '1'  then 'Film & Animation'
            when '2'  then 'Autos & Vehicles'
            when '10' then 'Music'
            when '15' then 'Pets & Animals'
            when '17' then 'Sports'
            when '18' then 'Short Movies'
