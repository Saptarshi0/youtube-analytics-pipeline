-- /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "youtube_analytics", "target_name": "dev", "node_id": "model.youtube_analytics.fct_momentum_videos"} */
create table "awsdatacatalog"."dbt_gold"."fct_momentum_videos__ha"
    with (
      table_type='iceberg',
