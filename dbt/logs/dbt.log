-- /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "youtube_analytics", "target_name": "dev", "node_id": "model.youtube_analytics.fct_top_channels"} */
create table "awsdatacatalog"."dbt_gold"."fct_top_channels__ha"
    with (
      table_type='iceberg',
      is_external=false,location='s3://youtube-analytics-gold-dev/dbt/dbt_gold/fct_top_channels/8f6b993a-af97-4d9b-97b3-a5b6ef272783',
      partitioning=ARRAY['region'],
      format='parquet'
    )
    as
      with channel_base as (
    select
        channel_id,
        channel_title,
        region,
        snapshot_date,
        trending_video_count,
        total_views,
        total_likes,
        total_comments,
        avg_view_count,
        avg_engagement_rate,
        max_video_views
    from "awsdatacatalog"."dbt_staging"."stg_channel_stats"
),

ranked as (
