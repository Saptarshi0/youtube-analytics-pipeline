create table "awsdatacatalog"."dbt_gold"."fct_momentum_videos__ha"
    with (
      table_type='iceberg',
      is_external=false,location='s3://youtube-analytics-gold-dev/dbt/dbt_gold/fct_momentum_videos/cc2a7e80-933c-46f2-b83c-2e3cc86e12eb',
