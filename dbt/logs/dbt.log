    trending_rank,
    view_count,
    like_count,
    comment_count,
    engagement_rate,
    like_to_view_ratio,
    duration_seconds,
    tags_count,
    published_date,
    days_to_trend,
    ntile(5) over (
        partition by region, snapshot_date
        order by engagement_rate desc
    ) as engagement_quintile
from with_age
order by region, snapshot_date, trending_rank
