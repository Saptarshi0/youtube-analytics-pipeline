-- /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "youtube_analytics", "target_name": "dev", "node_id": "model.youtube_analytics.fct_momentum_videos"} */
create table "awsdatacatalog"."dbt_gold"."fct_momentum_videos__ha"
    with (
      table_type='iceberg',
      is_external=false,location='s3://youtube-analytics-gold-dev/dbt/dbt_gold/fct_momentum_videos/28df6da6-2a10-43b8-bf31-8878586776b8',
      partitioning=ARRAY['region'],
      format='parquet'
    )
    as
      with velocity_base as (
    select *
